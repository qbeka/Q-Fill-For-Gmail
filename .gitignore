# ============================================================================
# Q-Fill for Gmail - .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Sensitive Configuration Files
# ----------------------------------------------------------------------------
config/config.js
manifest.json

# ----------------------------------------------------------------------------
# Website (separate repo)
# ----------------------------------------------------------------------------
website/.git/

# ----------------------------------------------------------------------------
# macOS
# ----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# ----------------------------------------------------------------------------
# Windows
# ----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# ----------------------------------------------------------------------------
# Node modules (if used for development tools)
# ----------------------------------------------------------------------------
node_modules/
package-lock.json
yarn.lock

# ----------------------------------------------------------------------------
# Build output / distribution folders
# ----------------------------------------------------------------------------
dist/
build/
out/
release/

# ----------------------------------------------------------------------------
# Log files
# ----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------------------------------------------------------------
# Temporary files and folders
# ----------------------------------------------------------------------------
tmp/
temp/
.tmp/
.temp/
*.tmp
*.temp

# ----------------------------------------------------------------------------
# Editor / IDE settings
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*~

# ----------------------------------------------------------------------------
# Chrome extension packaged files
# NEVER commit these - they should be built fresh each time
# ----------------------------------------------------------------------------
*.crx
*.pem
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz

# ----------------------------------------------------------------------------
# Test coverage and reports
# ----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# ----------------------------------------------------------------------------
# Environment files (may contain secrets)
# ----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.test
.env.production
*.env

# ----------------------------------------------------------------------------
# Backup files
# ----------------------------------------------------------------------------
*.bak
*.backup
*.old
